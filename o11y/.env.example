# Mobile app API key for /write endpoint
# Generate: openssl rand -hex 32
API_KEY=your-api-key-here

# Caddy basic auth for QuestDB web console
CADDY_ADMIN_USER=admin
# Password hash - generate with: docker run --rm caddy:2-alpine caddy hash-password --plaintext "yourpassword"
CADDY_ADMIN_PASS_HASH='$2a$14$...'

# QuestDB HTTP auth (defense-in-depth, Caddy handles primary auth)
QUESTDB_USER=admin
QUESTDB_PASSWORD=your-questdb-password-here

# Grafana admin password (optional - defaults to admin/admin, prompts to change on first login)
# Set via: fly secrets set GF_SECURITY_ADMIN_PASSWORD=your-password -a fastbreak-o11y
GF_SECURITY_ADMIN_PASSWORD=your-grafana-password-here
